{
  "name": "boundary-labs",
  "private": true,
  "engines": {
    "node": "22"
  },
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "dev": "pnpm --dir apps/web dev",
    "build": "pnpm --dir apps/web build",
    "start": "pnpm --dir apps/web start",
    "typecheck": "pnpm --dir apps/web typecheck",
    "verify:system": "python scripts/verify_system.py",
    "verify:readiness": "python scripts/verify_system.py --readiness",
    "audit:readiness": "python scripts/audit_readiness.py",
    "check:llm-agents": "python scripts/check_llm_agents.py",
    "check:provider-proof": "python scripts/check_provider_proof_config.py",
    "check:pydantic-evals": "python scripts/check_pydantic_evals.py"
  }
}
