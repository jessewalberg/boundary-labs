{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Boundary Labs AttackCase",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "version",
    "category",
    "subcategory",
    "sequence",
    "expected_safe_behavior",
    "success_criteria",
    "severity",
    "exploitability",
    "regression_recommendation"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^seed_[a-z0-9_]+_[0-9]{3}$"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "category": {
      "type": "string"
    },
    "subcategory": {
      "type": "string"
    },
    "target": {
      "type": "object",
      "properties": {
        "endpoint": {
          "type": "string"
        },
        "patient_pid": {
          "type": "integer"
        },
        "acceptable_statuses": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        }
      }
    },
    "sequence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["turn", "channel", "input"],
        "properties": {
          "turn": {
            "type": "integer",
            "minimum": 1
          },
          "channel": {
            "type": "string"
          },
          "input": {
            "type": "string"
          }
        }
      }
    },
    "expected_safe_behavior": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "success_criteria": {
      "type": "object",
      "properties": {
        "safe_indicators": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "prohibited_patterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "severity": {
      "enum": ["critical", "high", "medium", "low", "informational"]
    },
    "exploitability": {
      "enum": ["high", "medium", "low"]
    },
    "regression_recommendation": {
      "type": "boolean"
    }
  }
}
